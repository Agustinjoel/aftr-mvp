# AFTR - Variables de entorno (copiar a .env y completar)

# Obligatorio para refresco de partidos (football)
FOOTBALL_DATA_API_KEY=your_api_key_here

# Opcional: API-Sports (Basketball / NBA). Sin esto, NBA no se refresca.
# API_SPORTS_KEY=your_api_sports_key_here

# Opcional: ruta de la base SQLite (stats y evaluación de picks)
# AFTR_DB_PATH=./aftr.db
# DB_PATH=./aftr.db

# Opcional: liga por defecto en la UI
# AFTR_DEFAULT_LEAGUE=PL

# Opcional: probabilidad mínima para incluir un mercado como candidato (0.50 = 50%)
# AFTR_MIN_PROB=0.50

# Opcional: logging
# AFTR_LOG_LEVEL=INFO
# AFTR_DEBUG=0

# Refresco automático multi-tier (LIVE + UPCOMING + RESULTS). Refresco completo manual: python -m app.cli refresh
# AUTO_REFRESH=false
# LIVE_REFRESH_SECONDS=60
# LIVE_REFRESH_MIN_INTERVAL_SEC=30
# UPCOMING_REFRESH_MIN=15
# RESULTS_REFRESH_MIN=10
# REFRESH_BACKOFF_SECONDS=120
# RESULTS_FINISHED_HOURS=48
# ODDS_PREMATCH_HOURS=24
# ODDS_MIN_REFRESH_MINUTES=20
# FOOTBALL_HTTP_CACHE_TTL_SEC=45
# (legacy) REFRESH_EVERY_MIN=15  # si no defines UPCOMING_REFRESH_MIN, se usa como intervalo upcoming
# REFRESH_SKIP_IF_FRESH_MIN=30
# AUTO_REFRESH_LEAGUES_PER_CYCLE=4
# AUTO_REFRESH_FINISHED_DAYS=3
# AUTO_REFRESH_FETCH_ODDS=false
# RATE_LIMIT_COOLDOWN_CAP_SEC=600

# Si el proceso muere con refresh_running=true, tras N segundos se libera al leer meta (600 por defecto).
# Para refrescos muy largos, subir (p. ej. 1800). Para desarrollo agresivo: 120.
# REFRESH_RUNNING_TTL_SEC=600

API_SPORT_KEY=ae88b5b21b189904ca0c4e7e16d7fe5a