# ─────────────────────────────────────────────────────────────────
# .env.example  —  copiá este archivo a .env y completá los valores
# NUNCA subas .env a git (está en .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── Postgres (OBLIGATORIO) ─────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esto_en_produccion

# ── Seguridad (OBLIGATORIO) ────────────────────────────────────────
# genera con: openssl rand -hex 32
AFTR_SECRET_KEY=genera_con_openssl_rand_hex_32
APP_BASE_URL=https://aftrapp.online
COOKIE_SECURE=true

# ── API de datos (al menos API_FOOTBALL_KEY es obligatoria) ────────
API_FOOTBALL_KEY=tu_key_de_api_football
# API_SPORTS_KEY=        # NBA / otros deportes (opcional)

# ── MercadoPago ────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PLAN_ID=
MP_SUBSCRIPTION_AMOUNT=4999
MP_WEBHOOK_SECRET=

# ── Email transaccional (Resend vía SMTP) ──────────────────────────
SMTP_SERVER=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=tu_resend_api_key
EMAIL_FROM=noreply@aftrapp.online

# ── Push notifications (VAPID) ─────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:agustinjoelmastrocola@hotmail.com

# ── Gemini (match insights, opcional) ─────────────────────────────
GEMINI_API_KEY=

# ── Refresh automático ─────────────────────────────────────────────
AUTO_REFRESH=true
AUTO_REFRESH_LEAGUES_PER_CYCLE=18
AUTO_REFRESH_FINISHED_DAYS=3
REFRESH_SKIP_IF_FRESH_MIN=30

# ── Logs ───────────────────────────────────────────────────────────
AFTR_LOG_LEVEL=INFO
# AFTR_DEBUG=0

# ── Stripe (desactivado, dejar vacío) ─────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
